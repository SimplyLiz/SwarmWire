{
  "name": "swarmwire",
  "version": "1.4.0",
  "description": "TypeScript multi-agent orchestration library with budget-first design. Self-learning memory, vector search, 3-tier routing, 17 templates, knowledge graph, threat detection, ADRs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Lisa",
    "email": "lisa@tastehub.io",
    "url": "https://github.com/SimplyLiz"
  },
  "homepage": "https://github.com/SimplyLiz/SwarmWire#readme",
  "bugs": {
    "url": "https://github.com/SimplyLiz/SwarmWire/issues",
    "email": "lisa@tastehub.io"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/SimplyLiz/SwarmWire"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./patterns": {
      "import": "./dist/patterns/index.js",
      "types": "./dist/patterns/index.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./dist/transport/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    },
    "./memory/*": {
      "import": "./dist/memory/*.js",
      "types": "./dist/memory/*.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^20.14.11",
    "eslint": "^9.7.0",
    "openai": "^4.52.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.80.0",
    "openai": ">=4.52.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@anthropic-ai/claude-agent-sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/SimplyLiz/SwarmWire"
  },
  "keywords": [
    "multi-agent",
    "orchestration",
    "llm",
    "swarm",
    "ai-agents",
    "typescript",
    "budget",
    "coordination",
    "ai",
    "agent",
    "routing",
    "cascade",
    "cost-optimization",
    "guardrails",
    "evals",
    "record-replay",
    "testing",
    "mcp",
    "a2a",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "ollama",
    "sse",
    "plugin"
  ]
}
