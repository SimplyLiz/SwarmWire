{
  "name": "swarmwire",
  "version": "0.1.0",
  "description": "TypeScript multi-agent orchestration library with budget-first design",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./patterns": {
      "import": "./dist/patterns/index.js",
      "types": "./dist/patterns/index.d.ts"
    },
    "./memory/*": {
      "import": "./dist/memory/*.js",
      "types": "./dist/memory/*.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^20.14.11",
    "eslint": "^9.7.0",
    "openai": "^4.52.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.50.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true }
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/swarmwire/swarmwire"
  },
  "keywords": [
    "multi-agent",
    "orchestration",
    "llm",
    "swarm",
    "ai-agents",
    "typescript",
    "budget",
    "coordination"
  ]
}
